# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat ID (get from @userinfobot)
TELEGRAM_CHAT_ID=

# Optional: tune scoring threshold (0-100). Lower = more alerts. Default 60.
COMPOSITE_THRESHOLD=60

# Optional: minutes before re-alerting same stock. Default 60.
COOLDOWN_MINUTES=60

# Optional: scan interval in seconds. Default 300 (5 min).
# When using Fyers WebSocket (real-time ticks), drop this to 60.
SCAN_INTERVAL_SECONDS=300

# ============================================================================
# Fyers broker credentials (real-time price feed)
# ============================================================================
# Create an API app at https://myapi.fyers.in → "Create App" (App Type: 100).
# We use the manual OAuth flow (`python fyers_client.py auth`) so the only
# fields required are APP_ID, SECRET_ID, and REDIRECT_URI. PIN and TOTP are
# entered in your browser at login time, never stored on disk.
# WARNING: anyone with read access to this file can act on your Fyers app.
# Keep .env out of git and off shared drives.
# ============================================================================

FYERS_APP_ID=
FYERS_SECRET_ID=
FYERS_REDIRECT_URI=
